<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D0D">

    <!-- 搜索栏 -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:background="#1A1A1A">

        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="搜索..."
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@android:drawable/edit_text"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:imeOptions="actionSearch" />

        <Button
            android:id="@+id/btn_search_prev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="◀"
            android:textSize="12sp"
            android:padding="0dp"
            android:backgroundTint="#333333"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btn_search_next"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="▶"
            android:textSize="12sp"
            android:padding="0dp"
            android:backgroundTint="#333333"
            android:layout_marginStart="2dp" />

        <Button
            android:id="@+id/btn_search_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="14sp"
            android:padding="0dp"
            android:backgroundTint="#CC0000"
            android:layout_marginStart="2dp" />
    </LinearLayout>

    <!-- 替换栏 -->
    <LinearLayout
        android:id="@+id/replace_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:background="#1A1A1A">

        <EditText
            android:id="@+id/replace_input"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="替换为..."
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="@android:drawable/edit_text"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true" />

        <Button
            android:id="@+id/btn_replace_one"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="✓"
            android:textSize="14sp"
            android:padding="0dp"
            android:backgroundTint="#00E676"
            android:textColor="#000000"
            android:layout_marginStart="4dp" />

        <Button
            android:id="@+id/btn_replace_all"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text="≡"
            android:textSize="14sp"
            android:padding="0dp"
            android:backgroundTint="#333333"
            android:layout_marginStart="2dp" />

        <Button
            android:id="@+id/btn_replace_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="✕"
            android:textSize="14sp"
            android:padding="0dp"
            android:backgroundTint="#CC0000"
            android:layout_marginStart="2dp" />
    </LinearLayout>

    <!-- 编辑工具栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:gravity="center_vertical"
        android:background="#151515">

        <Button
            android:id="@+id/btn_select_all"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="全选"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_cut"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="剪切"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_copy"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="复制"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_paste"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="粘贴"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_search"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="搜索"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_replace"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="替换"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_undo"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="撤销"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_redo"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="重做"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:backgroundTint="#2A2A2A" />
    </LinearLayout>

    <EditText
        android:id="@+id/code_editor"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="top|start"
        android:padding="12dp"
        android:scrollbars="vertical"
        android:inputType="textMultiLine|textNoSuggestions" />

</LinearLayout>
